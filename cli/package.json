{
  "name": "dotnet-clean-arch",
  "version": "0.1.2",
  "description": "Install .NET Clean Architecture skills into Claude Code, Codex, Cursor, and GitHub Copilot via an interactive TUI.",
  "type": "module",
  "bin": {
    "dotnet-clean-arch": "./dist/cli.cjs"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsx scripts/bundle-skills.ts && tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "dotnet",
    "clean-architecture",
    "claude",
    "codex",
    "cursor",
    "copilot",
    "skills",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ronnythedev/dotnet-clean-architecture-skills"
  }
}
